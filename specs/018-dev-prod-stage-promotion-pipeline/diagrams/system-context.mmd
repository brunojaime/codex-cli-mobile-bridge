  User --> ProdApp
  ProdApp --> ProdBackend
  ProdBackend --> ProdAgent
  User --> SlashAction
  SlashAction --> DevQueue
  DevQueue --> DevBackend
  DevBackend --> StageRegistry
  StageRegistry --> Stage017
  StageRegistry --> Stage018
  StageRegistry --> StageChat
  StageChat --> DevBackend
  Stage017 --> MergeQueue
  Stage018 --> MergeQueue
  MergeQueue --> DevMain
  DevMain --> PromotionTool
  PromotionTool --> PromotionRecords
  PromotionTool --> ExistingScripts
  ExistingScripts --> ProdBackend
  PromotionTool --> GitHubActions
  GitHubActions --> AndroidRelease
  AndroidRelease --> ProdApp
  AndroidRelease --> DevApp
  DevApp --> DevBackend

  ProdAgent -. denied .-> DevLane
  ProdAgent -. denied .-> PromotionTool

