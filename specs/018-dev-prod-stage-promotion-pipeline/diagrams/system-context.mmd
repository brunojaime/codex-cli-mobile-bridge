  end

  subgraph ControlPlane[Control plane]
    DevQueue[DEV handoff queue]
    StageRegistry[Stage registry]
    MergeQueue[Merge queue]
    PromotionRecords[Promotion records and evidence]
    PromotionTool[Promotion orchestrator tool]
  end

  subgraph DevLane[DEV lane]
    DevApp[DEV mobile app]
    DevBackend[DEV backend]
    DevMain[dev/main]
    Stage017[spec-017 stage worktree]
    Stage018[spec-018 stage worktree]
    StageChat[Stage-bound chats]
  end

  subgraph ExternalBuilds[External deterministic services]
    GitHubActions[GitHub Actions Android release]
