BACKEND_MODE=local
SERVER_NAME=local-machine
USE_LAMBDA=false
CODEX_COMMAND=codex
CODEX_USE_EXEC=true
CODEX_EXEC_ARGS=--skip-git-repo-check --color never
CODEX_RESUME_ARGS=--skip-git-repo-check
CODEX_WORKDIR=.
PROJECTS_ROOT=/absolute/path/to/your/projects
TAILSCALE_SOCKET=/path/to/tailscaled.sock
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
LAMBDA_ENDPOINT=http://localhost:9000
EXECUTION_TIMEOUT_SECONDS=900
POLL_INTERVAL_SECONDS=2
