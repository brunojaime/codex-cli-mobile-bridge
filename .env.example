BACKEND_MODE=local
SERVER_NAME=local-machine
USE_LAMBDA=false
CODEX_COMMAND=codex
CODEX_USE_EXEC=true
CODEX_EXEC_ARGS=--skip-git-repo-check --color never --dangerously-bypass-approvals-and-sandbox
CODEX_RESUME_ARGS=--skip-git-repo-check --dangerously-bypass-approvals-and-sandbox
CODEX_WORKDIR=.
# Parent folder whose direct child directories appear in the "Choose Project" picker.
# Example: /home/alice/Documents/Projects or /Users/alice/Projects
PROJECTS_ROOT=/absolute/path/to/your/projects
CHAT_STORE_BACKEND=sqlite
CHAT_STORE_PATH=.data/chat_store.sqlite3
# Leave empty when using the normal system tailscaled service.
# Set it only if you run userspace tailscaled, for example:
# /home/alice/.local/share/tailscale-userspace/tailscaled.sock
TAILSCALE_SOCKET=
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
LAMBDA_ENDPOINT=http://localhost:9000
EXECUTION_TIMEOUT_SECONDS=0
POLL_INTERVAL_SECONDS=2
AUDIO_MAX_UPLOAD_BYTES=25000000
# Local transcription default for this repo. This uses faster-whisper on your machine.
AUDIO_TRANSCRIPTION_BACKEND=faster_whisper
AUDIO_TRANSCRIPTION_COMMAND=
# OpenAI-only setting. Ignored unless AUDIO_TRANSCRIPTION_BACKEND=openai.
AUDIO_TRANSCRIPTION_MODEL=whisper-1
AUDIO_TRANSCRIPTION_LANGUAGE=
AUDIO_TRANSCRIPTION_TIMEOUT_SECONDS=120
AUDIO_TRANSCRIPTION_LOCAL_MODEL=small
AUDIO_TRANSCRIPTION_LOCAL_COMPUTE_TYPE=int8
AUDIO_TRANSCRIPTION_LOCAL_DEVICE=auto
# OpenAI-only setting. Leave empty for local transcription.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
