{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex-cli-mobile-bridge/docs/check_git_https_snap.schema.json",
  "title": "check_git_https_snap.sh --json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "status", "stages"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "status": {
      "type": "string",
      "enum": ["passed", "failed"]
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "result", "message"],
        "properties": {
          "name": {
            "type": "string",
            "enum": ["lint", "harness"]
          },
          "result": {
            "type": "string",
            "enum": ["passed", "failed"]
          },
          "message": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
